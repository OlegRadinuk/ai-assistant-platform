# Минимально для запуска НИЧЕГО не нужно — приложение поднимется без секретов.

# Сессии (для прод — обязательно задать длинный random). В dev — fallback на dev-default.
SESSION_SECRET=replace-with-random-32+chars-in-production

# Claude API. Если НЕ задан — чат работает в mock-режиме (демо-ответы, без обмана).
ANTHROPIC_API_KEY=

# Опционально — прокси для Anthropic (для RU-серверов). По умолчанию — прямой api.anthropic.com.
ANTHROPIC_BASE_URL=

# Общий бот платформы (self-serve лиды + Telegram deep-link chat_id capture).
# Если не задан — Telegram-уведомления не отправляются (лиды только в БД).
TELEGRAM_BOT_TOKEN=
# Username бота (без @). Опционально — резолвится автоматически через getMe.
TELEGRAM_BOT_USERNAME=
# Базовый URL Telegram API. На РФ-хостинге api.telegram.org недоступен напрямую —
# укажи reverse-прокси (Cloudflare worker), формат пути тот же: <base>/bot<token>/<method>.
# Пусто = прямой https://api.telegram.org.
TELEGRAM_API_BASE=
# Секрет для аутентификации входящих Telegram webhook-запросов.
# Задать перед деплоем: openssl rand -hex 32
# Передаётся в setWebhook как secret_token. Telegram шлёт его в заголовке X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=

# База — путь к sqlite. По умолчанию ./data/app.db
DB_PATH=

# Базовый URL приложения (для генерации ссылок чата/виджета и Telegram webhook).
# В prod — обязательно: https://yourdomain.com
APP_BASE_URL=http://localhost:3100

# После деплоя зарегистрировать Telegram webhook:
#   node scripts/set-telegram-webhook.mjs
# (локально инертен — Telegram не может достучаться до localhost)
